# Voice Report — environment template
# Copy to .env and fill in real values. Do NOT commit your real .env.
# Variables marked (required) cause the app to fail loudly on boot if missing.

# ============================================================
# Database (required)
# Production lives in the shared `postgress_horizonsparks` container.
# The local `postgres` service in docker-compose.yml is unused.
# ============================================================
PG_HOST=postgress_horizonsparks
PG_PORT=5432
PG_DATABASE=horizon
PG_USER=horizon_spark
PG_PASSWORD=

# ============================================================
# Server (required)
# ============================================================
PORT=3070
HTTPS_PORT=3513
NODE_ENV=production
PUBLIC_BASE_URL=https://horizonsparks.com
CANONICAL_HOST=horizonsparks.com
# CSV of legacy hosts that should 301 → CANONICAL_HOST. Defaults to
# voice-report.ai,www.voice-report.ai when unset.
LEGACY_HOSTS=voice-report.ai,www.voice-report.ai

# ============================================================
# Authentication
# ============================================================
# (required) PIN that grants admin access via /api/login. Numeric or
# alphanumeric — equality-checked, no format constraints.
ADMIN_PIN=

# Cross-subdomain cookie for SSO across *.horizonsparks.ai. Leave unset
# for host-only cookies (default). Example: .horizonsparks.ai
COOKIE_DOMAIN=

# Keycloak SSO (required if cross-app SSO is in use)
KEYCLOAK_ISSUER=https://keycloak.horizonsparks.ai/realms/app
KEYCLOAK_AUDIENCE=app
KEYCLOAK_OIDC_CLIENT_ID=app
KEYCLOAK_OIDC_CLIENT_SECRET=
# Optional — derived from KEYCLOAK_ISSUER if omitted.
# KEYCLOAK_JWKS_URL=

# Web Push (VAPID). Generate a fresh pair per environment:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Without these, /api/push endpoints return 503 and the client UI hides
# the subscribe button — the rest of the app keeps working.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:admin@example.com

# ============================================================
# Integration keys (server-to-server auth)
# ============================================================
# Legacy key — also exposed via NEXT_PUBLIC_ on the LoopFolders side,
# so treat as semi-public. Scheduled for refactor.
INTEGRATION_KEY=

# Server-only key for the PIDS-app support proxy. Never expose to a
# browser. sessionAuth accepts EITHER INTEGRATION_KEY or this one, so
# they can be rotated independently.
INTEGRATION_KEY_SUPPORT=

# ============================================================
# AI providers (required)
# ============================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ============================================================
# Stripe billing
# ============================================================
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================================
# Support module
# ============================================================
# IANA timezone for "business hours" evaluation in the AI auto-reply
# and /api/support/status. Default: America/Mexico_City.
SUPPORT_TIMEZONE=America/Mexico_City

# ============================================================
# Observability
# ============================================================
SENTRY_DSN_BACKEND=
GLITCHTIP_URL=
GLITCHTIP_PUBLIC_URL=
PROMETHEUS_URL=
GRAFANA_URL=
LOKI_URL=
# DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# ============================================================
# Multi-tenant database routing (advanced — leave default)
# ============================================================
# Set to 'true' only if per-company physical databases are enabled.
# Default: false (single shared `horizon` DB with company_id partitioning).
USE_COMPANY_DBS=false
